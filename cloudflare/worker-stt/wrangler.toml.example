main = "worker.js"
compatibility_date = "2026-06-01"

[ai]
binding = "AI"

# To deploy:
#   1. Install wrangler: npm install -g wrangler
#   2. Login: npx wrangler login
#   3. Deploy: npx wrangler deploy
