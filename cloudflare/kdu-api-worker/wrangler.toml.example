name = "kdu-api-worker"
main = "worker.js"
compatibility_date = "2026-06-01"

# Workers AI binding (for STT transcription and embeddings)
[ai]
binding = "AI"

# ── Optional bindings — uncomment when ready ──────────────────────────────────

# Vectorize index (for RAG / semantic search) — requires paid plan
# [[vectorize]]
# binding = "VECTORIZE"
# index_name = "kdu-study-vectors"

# D1 database (for cloud progress storage)
# [[d1_databases]]
# binding = "DB"
# database_name = "kdu-progress"
# database_id = "your-d1-database-id"

# KV namespace (for caching/config)
# [[kv_namespaces]]
# binding = "KV"
# id = "your-kv-namespace-id"

# R2 bucket (for file storage)
# [[r2_buckets]]
# binding = "R2"
# bucket_name = "kdu-files"

# ── Secrets — set via CLI, never in this file ──────────────────────────────────
# npx wrangler secret put MOONSHOT_API_KEY
# npx wrangler secret put GROQ_API_KEY
#
# Environment variable (optional):
# [vars]
# DEFAULT_MODEL = "moonshot-v1-8k"

# ── Deployment instructions ────────────────────────────────────────────────────
# 1. Install wrangler:   npm install -g wrangler
# 2. Login:              npx wrangler login
# 3. Copy this file to wrangler.toml and fill in your IDs
# 4. Set secrets:        npx wrangler secret put MOONSHOT_API_KEY
# 5. Deploy:             npx wrangler deploy
# 6. Test:               curl https://your-worker.workers.dev/health
