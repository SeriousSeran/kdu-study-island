# KDU API Worker — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the .env file — it is in .gitignore.

# Moonshot / Kimi API key
MOONSHOT_API_KEY=sk-your-moonshot-key-here

# Groq API key (for STT fallback if still using Groq directly)
GROQ_API_KEY=gsk_your-groq-key-here

# Optional: AI Gateway URL (if routing through Cloudflare AI Gateway)
# AI_GATEWAY_URL=https://gateway.ai.cloudflare.com/v1/your-account-id/your-gateway-name
